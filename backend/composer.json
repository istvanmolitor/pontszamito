{
  "name": "pontszamito/backend",
  "description": "Simple PHP API for subject listing",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "start": "php -S 127.0.0.1:8000 -t public public/index.php",
    "test": "phpunit"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  }
}
